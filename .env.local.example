# ======================================================
# 網站網址（部署後改成你的正式網域）
# ======================================================
NEXT_PUBLIC_SITE_URL=https://anomieblog.vercel.app

# ======================================================
# Firebase 客戶端（瀏覽器端使用，加 NEXT_PUBLIC_ 前綴）
# 在 Firebase Console > 專案設定 > 你的應用程式 > 複製設定
# ======================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ======================================================
# Firebase Admin SDK（伺服器端 SSR 使用，不加 NEXT_PUBLIC_）
# 在 Firebase Console > 專案設定 > 服務帳戶 > 產生新的私密金鑰
# ======================================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 注意：私密金鑰中的換行符需替換成 \n
FIREBASE_PRIVATE_KEY=

# ======================================================
# Giscus 留言系統
# 至 https://giscus.app 設定後複製貼上
# ======================================================
NEXT_PUBLIC_GISCUS_REPO=your-github-username/your-repo
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# ======================================================
# Buttondown 電子報（https://buttondown.email，免費方案）
# 在 Buttondown > Settings > API 取得
# ======================================================
BUTTONDOWN_API_KEY=
